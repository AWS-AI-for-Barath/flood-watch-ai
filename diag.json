{
  "processFloodAI": {
    "runtime": "nodejs20.x",
    "handler": "index.handler",
    "timeout": 30,
    "memory": 512,
    "state": "Active",
    "env": {
      "FLOODWATCH_USE_BEDROCK": "true"
    }
  },
  "s3_notifications": {
    "LambdaFunctionConfigurations": [
      {
        "Id": "12a1c36d-9a36-4b63-8844-3dc6f1e03c4e",
        "LambdaFunctionArn": "arn:aws:lambda:us-east-1:246950780510:function:processFloodAI",
        "Events": [
          "s3:ObjectCreated:Put"
        ],
        "Filter": {
          "Key": {
            "FilterRules": [
              {
                "Name": "Prefix",
                "Value": "media/"
              }
            ]
          }
        }
      },
      {
        "Id": "b9a31754-e5ae-42b3-a90b-444b9f3f2731",
        "LambdaFunctionArn": "arn:aws:lambda:us-east-1:246950780510:function:transformFloodPolygon",
        "Events": [
          "s3:ObjectCreated:Put"
        ],
        "Filter": {
          "Key": {
            "FilterRules": [
              {
                "Name": "Prefix",
                "Value": "analysis/"
              },
              {
                "Name": "Suffix",
                "Value": "{}.json"
              }
            ]
          }
        }
      }
    ]
  },
  "invoke_processFloodAI": {
    "status": 200,
    "error": null,
    "body": "{\"statusCode\":500,\"body\":\"{\\\"status\\\":\\\"error\\\",\\\"message\\\":\\\"The model returned the following errors: The provided image could not be processed. Try again with a valid image.\\\"}\"}"
  },
  "transformFloodPolygon": {
    "runtime": "python3.10",
    "handler": "lambda_function.handler",
    "timeout": 30,
    "memory": 512,
    "state": "Active",
    "env": {
      "DB_PASS": "",
      "DB_PORT": "5432",
      "DB_USER": "postgres",
      "DB_NAME": "floodwatch",
      "DB_HOST": "database-1.ckdm4y6i86ke.us-east-1.rds.amazonaws.com",
      "BUCKET_NAME": "floodwatch-uploads"
    }
  },
  "routingLambda": {
    "runtime": "python3.10",
    "handler": "phase4_routing.routing.lambda_handler.handler",
    "timeout": 30,
    "state": "Active",
    "env": {
      "DB_PASS": "",
      "DB_PORT": "5432",
      "DB_USER": "postgres",
      "OSRM_ENDPOINT": "https://router.project-osrm.org",
      "OSRM_MOCK": "0",
      "FLOODWATCH_DB_MODE": "production",
      "DB_NAME": "floodwatch",
      "DB_HOST": "database-1.ckdm4y6i86ke.us-east-1.rds.amazonaws.com"
    }
  },
  "processFloodAlerts": {
    "runtime": "python3.12",
    "handler": "lambda_handler.handler",
    "timeout": 60,
    "state": "Active",
    "env": {
      "DB_PASS": "postgres",
      "DB_PORT": "5432",
      "FLOODWATCH_ALERT_MODE": "production",
      "DB_USER": "postgres",
      "DB_NAME": "floodwatch",
      "DB_HOST": "database-1.ckdm4y6i86ke.us-east-1.rds.amazonaws.com"
    }
  },
  "simulateFloodPropagation": {
    "runtime": "python3.12",
    "handler": "lambda_handler.handler",
    "timeout": 60,
    "state": "Active",
    "env": {
      "DB_PASS": "postgres",
      "DB_PORT": "5432",
      "DB_USER": "postgres",
      "FLOODWATCH_DB_MODE": "production",
      "DB_NAME": "floodwatch",
      "DB_HOST": "database-1.ckdm4y6i86ke.us-east-1.rds.amazonaws.com"
    }
  }
}
